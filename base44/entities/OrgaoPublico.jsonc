      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Modalidades de Ensino"
    }
  },
  "required": [
    "nome",
    "esfera"
  ],
  "rls": {
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "Administrador"
          }
        },
        {
          "created_by": "{{user.email}}"
        },
        {
          "data.responsavel_id": "{{user.email}}"
        },
        {
          "data.responsavel_gestor_id": "{{user.email}}"
        }
      ]
    },
    "update": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "Administrador"
          }
        },
        {
          "created_by": "{{user.email}}"
        },
        {
          "data.responsavel_id": "{{user.email}}"
        },
        {
          "data.responsavel_gestor_id": "{{user.email}}"
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "Administrador"
          }
        },
        {
          "created_by": "{{user.email}}"
        }
      ]
    }
  }
}